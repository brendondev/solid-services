# Environment para testes E2E

# Database
# IMPORTANTE: Configure com seu banco PostgreSQL de desenvolvimento
# Exemplo: DATABASE_URL="postgresql://postgres:postgres@localhost:5432/solid_service"
# Os testes criarão dados temporários (usa timestamps únicos nos slugs)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# JWT
JWT_SECRET="test-secret-key-for-e2e-tests-only"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# S3 (mock para testes)
AWS_ACCESS_KEY_ID="test-key"
AWS_SECRET_ACCESS_KEY="test-secret"
AWS_REGION="us-east-1"
S3_BUCKET="test-bucket"

# Email (desabilitado para testes)
RESEND_API_KEY=""
FROM_EMAIL="noreply@test.com"

# Portal URL
PORTAL_URL="http://localhost:3001/portal"
